# Backend Service URLs
BACKEND_URL=https://vscode-internal-13987-qa.qa01.cloud.kavia.ai:3001
FRONTEND_URL=https://vscode-internal-13987-qa.qa01.cloud.kavia.ai:3000
WS_URL=ws://vscode-internal-13987-qa.qa01.cloud.kavia.ai:3001/ws
SITE_URL=https://vscode-internal-13987-qa.qa01.cloud.kavia.ai:3000

# CORS Configuration
ALLOWED_ORIGINS=https://vscode-internal-13987-qa.qa01.cloud.kavia.ai:3000,http://localhost:3000
ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With
ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_MAX_AGE=3600

# Server Configuration
HOST=0.0.0.0
UVICORN_HOST=0.0.0.0
UVICORN_WORKERS=1
PORT=3001

# Database Connection (provided by database container)
POSTGRES_URL=postgresql://localhost:5000/myapp
POSTGRES_USER=appuser
POSTGRES_PASSWORD=dbuser123
POSTGRES_DB=myapp
POSTGRES_PORT=5000

# JWT Authentication Settings
# IMPORTANT: Change JWT_SECRET_KEY in production to a secure random string (min 32 characters)
JWT_SECRET_KEY=your-secret-key-change-in-production-min-32-chars-recommended
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Optional Settings
NODE_ENV=development
REQUEST_TIMEOUT_MS=30000
RATE_LIMIT_WINDOW_S=60
RATE_LIMIT_MAX=100
COOKIE_DOMAIN=.vscode-internal-13987-qa.qa01.cloud.kavia.ai
TRUST_PROXY=true
